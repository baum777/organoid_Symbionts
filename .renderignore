# Render Ignore — Prevent Python/Docker detection
# This is a Node.js/TypeScript project

# Docker files (legacy)
Dockerfile*
docker-compose*
.dockerignore

# Python files (legacy)
*.py
*.pyc
__pycache__/
.pytest_cache/
.venv/
venv/

# Legacy Python project
legacy/python/
llm-terminal-test-bundle/
tools/behavior_fingerprint/

# Python config (legacy)
requirements*.txt
pyproject.toml*
requirements-dev.txt

# Node modules (handled by buildCommand)
node_modules/

# Build output (generated)
dist/

# Data files (runtime)
data/
state/

# Logs
logs/
*.log

# Test coverage
coverage/
.nyc_output/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
