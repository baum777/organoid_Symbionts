# Dockerfile.ollama — LFM2.5-1.2B sidecar for Phase 1 Pre-LLM tier.
# Pre-pulls the model at build time to avoid cold-start at runtime.
FROM ollama/ollama:latest

RUN ollama serve & \
    sleep 5 && \
    ollama pull lfm2.5:1.2b-instruct && \
    pkill ollama

EXPOSE 11434
ENTRYPOINT ["ollama", "serve"]
