{
  "name": "gnomes-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "demo:render": "tsx scripts/render_demo.ts",
    "simulate": "tsx scripts/simulateConversation.ts",
    "simulate:ci": "tsx scripts/simulateConversation.ts --strict",
    "snippets:extract": "tsx src/persona/dailySnippetExtractor.ts",
    "poll": "tsx -r dotenv/config src/index.ts",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:stress": "vitest run tests/stress/personaStress.test.ts",
    "test:watch": "vitest",
    "test:critical": "vitest run tests/critical",
    "test:smoke": "vitest run tests/smoke",
    "test:e2e": "vitest run tests/e2e",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "persona:build-semantic": "tsx scripts/build-persona-semantic-index.ts --split"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.0",
    "js-yaml": "^4.1.0",
    "openai": "6.27.0",
    "replicate": "^1.0.0",
    "sharp": "^0.33.5",
    "twitter-api-v2": "^1.15.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.17.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
