{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gorky.bot/schemas/mention_signal.json",
  "title": "MentionSignal",
  "description": "Raw X/Twitter mention input from API",
  "type": "object",
  "required": ["id", "text", "author_id"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "description": "Tweet ID" },
    "text": { "type": "string", "description": "Tweet text" },
    "author_id": { "type": "string", "description": "Author user ID" },
    "authorUsername": { "type": ["string", "null"], "description": "Author handle without @" },
    "conversation_id": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" },
    "referenced_tweets": {
      "type": ["array", "null"],
      "items": { "type": "object", "properties": { "type": { "type": "string" }, "id": { "type": "string" } } }
    },
    "in_reply_to_user_id": { "type": ["string", "null"] }
  }
}
