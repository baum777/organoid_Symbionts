{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gorky.bot/schemas/normalized_event.json",
  "title": "NormalizedEvent",
  "description": "Canonical internal event (CanonicalEvent)",
  "type": "object",
  "required": ["event_id", "platform", "trigger_type", "author_handle", "author_id", "text", "timestamp"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string" },
    "platform": { "type": "string", "enum": ["twitter"] },
    "trigger_type": { "type": "string", "enum": ["mention", "reply", "quote", "manual"] },
    "author_handle": { "type": "string" },
    "author_id": { "type": "string" },
    "text": { "type": "string" },
    "parent_text": { "type": ["string", "null"] },
    "quoted_text": { "type": ["string", "null"] },
    "conversation_context": { "type": "array", "items": { "type": "string" } },
    "cashtags": { "type": "array", "items": { "type": "string" } },
    "hashtags": { "type": "array", "items": { "type": "string" } },
    "urls": { "type": "array", "items": { "type": "string" } },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
