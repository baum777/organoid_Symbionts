{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gorky.bot/schemas/relevance_result.json",
  "title": "RelevanceResult",
  "description": "Relevance score breakdown and eligibility decision",
  "type": "object",
  "required": ["score", "components"],
  "additionalProperties": false,
  "properties": {
    "score": { "type": "number", "minimum": 0, "maximum": 1 },
    "components": {
      "type": "object",
      "properties": {
        "mention_signal": { "type": "number" },
        "narrative_relevance": { "type": "number" },
        "roastability": { "type": "number" },
        "analytical_opportunity": { "type": "number" },
        "sentiment_intensity": { "type": "number" },
        "risk_penalty": { "type": "number" }
      }
    },
    "eligible": { "type": "boolean" },
    "skip_reason": { "type": "string" }
  }
}
