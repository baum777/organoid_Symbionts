{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gorky.bot/schemas/analytics_log.json",
  "title": "AnalyticsLog",
  "description": "Structured audit event for analytics",
  "type": "object",
  "required": ["event_id", "created_at"],
  "additionalProperties": true,
  "properties": {
    "event_id": { "type": "string" },
    "source_tweet_id": { "type": "string" },
    "user_id": { "type": "string" },
    "cleaned_text_hash": { "type": "string" },
    "safety_result": { "type": "string", "enum": ["pass", "block"] },
    "relevance_score": { "type": "number" },
    "sentiment_score": { "type": "number" },
    "detected_narrative": { "type": "string" },
    "selected_pattern": { "type": "string" },
    "response_mode": { "type": "string", "enum": ["short", "expanded", "thread"] },
    "generation_status": { "type": "string", "enum": ["success", "fail", "repair"] },
    "validation_result": { "type": "string", "enum": ["pass", "fail_soft", "fail_hard"] },
    "publish_decision": { "type": "string", "enum": ["publish", "skip", "defer"] },
    "skip_reason": { "type": ["string", "null"] },
    "final_text_hash": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
