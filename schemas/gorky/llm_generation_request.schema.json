{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gorky.bot/schemas/llm_generation_request.json",
  "title": "LlmGenerationRequest",
  "description": "Everything needed by LLM generation",
  "type": "object",
  "required": ["system", "user"],
  "additionalProperties": true,
  "properties": {
    "system": { "type": "string" },
    "developer": { "type": "string" },
    "user": { "type": "string" },
    "pattern_id": { "type": "string" },
    "narrative_label": { "type": "string" },
    "format_target": { "type": "string" },
    "max_tokens": { "type": "integer" }
  }
}
